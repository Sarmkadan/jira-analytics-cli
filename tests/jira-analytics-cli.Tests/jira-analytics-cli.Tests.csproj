    <Compile Include="..\..\Models\SprintMetric.cs" />
    <Compile Include="..\..\Models\Developer.cs" />
    <Compile Include="..\..\Models\BurndownSnapshot.cs" />
    <Compile Include="..\..\Models\JiraProject.cs" />
    <Compile Include="..\..\Services\IAnalyticsService.cs" />
    <Compile Include="..\..\Services\IJiraApiService.cs" />
    <Compile Include="..\..\Services\AnalyticsService.cs" />
    <Compile Include="..\..\Services\IJqlQueryService.cs" />
    <Compile Include="..\..\Services\JqlQueryService.cs" />
    <Compile Include="..\..\Services\IHtmlReportService.cs" />
    <Compile Include="..\..\Services\HtmlReportService.cs" />
    <Compile Include="..\..\Services\ITeamComparisonService.cs" />
